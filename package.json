{
  "name": "botch-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/ensure-aws-crypto-tsconfig.mjs",
    "rebuild:sqlite": "npm rebuild better-sqlite3",
    "dev": "node scripts/run-with-restart.js",
    "build": "node --no-deprecation -c src/index.js",
    "start": "node --no-deprecation src/index.js",
    "db:migrate": "node src/db/migrate.js",
    "db:schema:mysql": "node src/db/apply-mysql-sql.js schema.mysql.sql",
    "db:schema:mysql:phpmyadmin": "node scripts/generate-schema-mysql-phpmyadmin.mjs",
    "db:seed:mysql": "node src/db/apply-mysql-sql.js seed.mysql.sql",
    "db:seed:mysql:export": "node scripts/export-sqlite-to-mysql-seed.mjs",
    "db:setup:mysql": "node scripts/setup-mysql.js",
    "db:ensure-super-admin": "node scripts/ensure-super-admin.js",
    "db:backup": "node scripts/backup.js",
    "env:check:prod": "node scripts/check-required-env.js",
    "package:hostinger": "node scripts/package-hostinger.js",
    "db:seed": "node src/db/seed-sqlite.js",
    "add-invoice": "node scripts/add-pending-invoice.js",
    "test-paystack": "node scripts/test-paystack-key.js",
    "test": "node tests/api.test.js",
    "test:unit": "node --test \"tests/unit/*.test.js\"",
    "test:integration": "node --test tests/integration/api.test.js",
    "test:coverage": "c8 --include=src --exclude=tests --reporter=text --reporter=lcov --check-coverage --lines 80 --statements 80 node --test \"tests/unit/*.test.js\""
  },
  "dependencies": {
    "@arcjet/node": "^1.4.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@paystack/paystack-sdk": "^1.0.1",
    "@sentry/node": "^10.51.0",
    "@simplewebauthn/server": "^13.3.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.3",
    "node-pg-migrate": "^6.2.2",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "pm2": "^7.0.1",
    "socket.io": "^4.7.5",
    "speakeasy": "^2.0.0",
    "stripe": "^20.4.1",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "nodemon": "^3.1.14"
  },
  "overrides": {
    "typeid-js": {
      "uuid": "^11.1.1"
    },
    "pm2": {
      "ws": "^8.20.1"
    }
  }
}
