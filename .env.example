# Server
NODE_ENV=development
PORT=4000
# Bind address (default 0.0.0.0). Use 127.0.0.1 to accept only local connections.
# LISTEN_HOST=0.0.0.0
API_VERSION=v1

# Database
# MySQL (Hostinger production): mysql:// or mariadb:// — see docs/MYSQL-MIGRATION.md
# DATABASE_URL=mysql://user:password@localhost:3306/botch_db
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=botch_user
# MYSQL_PASSWORD=
# MYSQL_DATABASE=botch_db
# PostgreSQL schema.sql exists but pg pool is not wired (do not use postgres:// yet).
# SQLite (default when DATABASE_URL unset): botch.db in backend folder. See docs/PRODUCTION-DATABASE.md
# SQLITE_PATH=/data/botch.db
# Uploads: in production (e.g. Render) set to a persistent path so attachments persist (e.g. /data/private_uploads). Startup checks writable when set.
# UPLOADS_PATH=/data/private_uploads
# Optional: same random string on Render + Vercel; Next.js /uploads proxy sends X-Botch-Uploads-Proxy so direct /uploads hotlinks to the API 403.
# UPLOADS_PROXY_SECRET=generate-a-long-random-string
# Expose Swagger at /api-docs in production (default: off). Dev always has /api-docs.
# ENABLE_API_DOCS=false

# Arcjet (optional) — Shield + bot scoring on the API (Render). No key → middleware is a no-op.
# Stripe + KYC webhooks, Socket.IO (/api/socket-io), /uploads, /api/health are bypassed automatically.
# Bot rule defaults to DRY_RUN (log-only): set ARCJET_BOT_MODE=LIVE when you trust the footprint.
# ARCJET_KEY=
# ARCJET_ENABLED=true
# ARCJET_SHIELD_MODE=LIVE
# ARCJET_BOT_MODE=DRY_RUN
# ARCJET_TRUSTED_PROXIES=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# 2FA
TWO_FA_ISSUER=Botch Realties
# Require MFA for admin, super_admin, and vendor (dashboard and privileged actions). Default: off. Set to true to enforce (admins must enable 2FA).
# MFA_ENFORCE_ADMIN_AGENT=true

# Login OTP (optional: require 6-digit code at login)
LOGIN_OTP_ENABLED=false

# Session timeout (ms); 0 to disable. Default 30 min
SESSION_TIMEOUT_MS=1800000

# Bank transfer (for client display)
BANK_NAME=
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_NAME=Botch Realties
BANK_SORT_CODE=
BANK_REFERENCE_PREFIX=BOTCH

# Payments (optional for dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
# Paystack supported currencies (comma-separated). Default: GHS,USD. Ghana = GHS only; Nigeria/Kenya = GHS,USD.
PAYSTACK_CURRENCIES=GHS,USD
# When invoice is USD but merchant only supports GHS, convert using this rate (e.g. 1 USD = 15 GHS).
PAYSTACK_USD_TO_GHS=15
# Public calculator base rate in GHS per square meter (used by /api/v1/public-config)
CALCULATOR_BASE_PER_SQM_GHS=4200
# Building cost calculator — Nigerian Naira per sqm baseline (resources/calculator wizard)
CALCULATOR_BASE_PER_SQM_NGN=135000

# AWS S3 (optional for dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=botch-media
# Optional CDN URL for media/invoices (no trailing slash)
CLOUDFRONT_URL=

# Email (optional for dev — no emails sent if not set; required for forgot-password in production)
# Option A: Resend — set RESEND_API_KEY (uses smtp.resend.com with "resend" username)
# For Resend, set MAIL_FROM_EMAIL to a verified sender/domain in your Resend account.
RESEND_API_KEY=
# Option B: SendGrid — set SENDGRID_API_KEY (use SMTP with apikey as user)
# For SendGrid, set MAIL_FROM_EMAIL to a verified sender (SendGrid → Sender Authentication). See docs/EMAIL-SETUP.md.
SENDGRID_API_KEY=
# Option C: Generic SMTP (Mailtrap, Gmail, etc.)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@botchrealties.com
MAIL_FROM_EMAIL=

# SMS (optional for dev)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Video / voice calls (in-app): create an API Key in Twilio Console → Account → API keys & tokens.
# Use TWILIO_ACCOUNT_SID (starts with AC), TWILIO_API_KEY_SID (starts with SK), TWILIO_API_KEY_SECRET (Secret shown once when you create the key).
# If any of these are missing or wrong, video and voice call buttons will show a setup error.
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_twilio_api_key_secret

# Frontend URL (for CORS and Socket.IO). In production (e.g. Render) set to your live site.
# Example: https://www.botchrealty.com — both www and non-www are allowed automatically.
# Comma-separated for multiple frontends. ADDITIONAL_CORS_ORIGINS adds extra origins (e.g. preview deploys).
FRONTEND_URL=http://localhost:3000
# ADDITIONAL_CORS_ORIGINS=https://preview-abc.vercel.app,https://staging.example.com

# Max size in bytes for progress media uploads (default 25MB, max 100MB). Multer enforces this.
# UPLOAD_MAX_MEDIA_BYTES=26214400

# Backend URL (for receipt/media links in emails)
BACKEND_URL=http://localhost:4000

# Backend public URL for Socket.IO (optional). When the frontend fetches /api/ws-origin it uses this so Socket.IO connects to the right host. On Render, RENDER_EXTERNAL_URL is set automatically; elsewhere set e.g. BACKEND_PUBLIC_URL=https://your-api.example.com
# BACKEND_PUBLIC_URL=https://your-backend.onrender.com

# KYC/AML — show "Start secure verification" button and optional redirect
# Leave unset or set to a URL template. Placeholders: {userId} {sessionId} {documentType}
# In development the button shows even if unset. For production, set to your provider (e.g. Smile ID / Sumsub).
# Example (redirects back to your app until you set a real provider):
KYC_HOSTED_URL_TEMPLATE=http://localhost:3000/dashboard/verification?hosted=1&session={sessionId}
# KYC_PROVIDER=manual
# KYC_WEBHOOK_SECRET=

# Sumsub (when KYC_PROVIDER=sumsub) — Web SDK + webhooks
# Get App Token and Secret from Sumsub Dashboard → App tokens. Use Sandbox tokens for testing.
# SUMSUB_APP_TOKEN=
# SUMSUB_SECRET_KEY=
# SUMSUB_BASE_URL=https://api-sandbox.sumsub.com
# SUMSUB_LEVEL_NAME=basic-kyc-level
# Optional: Web SDK script/iframe base (default: sandbox-cdn.sumsub.com or cdn.sumsub.com)
# SUMSUB_WEB_SDK_BASE_URL=
# Webhook: set the same secret in Sumsub Dashboard → Webhooks → Secret. Backend accepts X-Webhook-Secret or X-Payload-Digest.
# KYC_WEBHOOK_SECRET=your-sumsub-webhook-secret
